{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-secrets.sh",
            "shell": "bash",
            "timeout": 10,
            "statusMessage": "Scanning staged changes for secrets..."
          }
        ]
      }
    ]
  }
}
